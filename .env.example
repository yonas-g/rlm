# Shared config (used if root/sub-specific vars are not set)
RLM_API_KEY=your-api-key-here
RLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/

# Root model (top-level queries)
RLM_ROOT_MODEL=gemini-3-flash-preview
# RLM_ROOT_API_KEY=       # falls back to RLM_API_KEY
# RLM_ROOT_BASE_URL=      # falls back to RLM_BASE_URL

# Sub model (recursive sub-calls — can use a cheaper model)
RLM_SUB_MODEL=gemini-3-flash-preview
# RLM_SUB_API_KEY=        # falls back to RLM_ROOT_API_KEY
# RLM_SUB_BASE_URL=       # falls back to RLM_ROOT_BASE_URL
